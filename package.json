{
  "name": "feishu-opencode-bridge",
  "version": "0.2.2",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint src test scripts --ext .ts",
    "lint:deps": "depcruise --config .dependency-cruiser.cjs src",
    "check:formatter-exports": "tsx scripts/checks/check-formatter-exports.ts",
    "check:docs-diff": "tsx scripts/checks/check-docs-diff.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "onboard": "node scripts/runtime/onboard.mjs",
    "bootstrap": "node scripts/runtime/bootstrap.mjs",
    "doctor": "node scripts/runtime/doctor.mjs",
    "cost": "node scripts/runtime/cost.mjs",
    "update:portable": "node scripts/runtime/update.mjs",
    "ext:install": "node scripts/ext/ext.mjs install",
    "ext:list": "node scripts/ext/ext.mjs list",
    "ext:remove": "node scripts/ext/ext.mjs remove",
    "ext:pack": "node scripts/ext/ext.mjs pack",
    "kb": "tsx scripts/kb/kb.ts",
    "files": "tsx bin/files.ts",
    "bridge": "tsx bin/bridge.ts",
    "labor:harness": "tsx scripts/labor/harness.ts",
    "cards:preview": "tsx scripts/cards/preview.ts",
    "dev": "tsx watch src/index.ts",
    "dev:once": "tsx src/index.ts",
    "dev:bridge": "tsx watch src/index.ts",
    "dev:stack": ".\\start-local-stack.cmd",
    "start": "node dist/src/index.js",
    "start:stack": "node scripts/runtime/start.mjs",
    "release:portable": "node scripts/release/build-portable.mjs"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.5.1",
    "@larksuiteoapi/node-sdk": "^1.42.0",
    "better-sqlite3": "^12.8.0",
    "docxtemplater": "^3.68.4",
    "mammoth": "^1.12.0",
    "node-cron": "^4.2.1",
    "pdf-parse": "^2.4.5",
    "pizzip": "^3.2.0",
    "ws": "^8.18.0",
    "xlsx": "^0.18.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.13.10",
    "@types/ws": "^8.5.14",
    "@typescript-eslint/eslint-plugin": "^8.26.0",
    "@typescript-eslint/parser": "^8.26.0",
    "dependency-cruiser": "^17.3.10",
    "eslint": "^8.57.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.2.4"
  }
}
