{
  "name": "feishu-opencode-bridge",
  "version": "0.1.24",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint src test scripts --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "onboard": "node scripts/onboard.mjs",
    "doctor": "node scripts/doctor.mjs",
    "kb": "tsx scripts/kb.ts",
    "kb_query": "tsx scripts/kb-query.ts",
    "kb_ingest_file": "tsx scripts/kb-ingest-file.ts",
    "kb_ingest_url": "tsx scripts/kb-ingest-url.ts",
    "dev": "tsx watch src/index.ts",
    "dev:once": "tsx src/index.ts",
    "dev:bridge": "tsx watch src/index.ts",
    "dev:stack": ".\\start-local-stack.cmd",
    "start": "node dist/src/index.js"
  },
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.42.0",
    "better-sqlite3": "^12.8.0",
    "docxtemplater": "^3.68.4",
    "mammoth": "^1.12.0",
    "node-cron": "^4.2.1",
    "pdf-parse": "^2.4.5",
    "pizzip": "^3.2.0",
    "ws": "^8.18.0",
    "xlsx": "^0.18.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.13.10",
    "@types/ws": "^8.5.14",
    "@typescript-eslint/eslint-plugin": "^8.26.0",
    "@typescript-eslint/parser": "^8.26.0",
    "eslint": "^8.57.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.2.4"
  }
}
