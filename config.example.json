{
  "feishu": {
    "appId": "cli_xxx",
    "appSecret": "xxx",
    "botOpenId": "ou_xxx",
    "botOpenIds": ["ou_xxx", "ou_yyy"],
    "botMentionNames": ["opencode", "open code"],
    "selfBotOpenId": "ou_xxx",
    "selfBotOpenIds": ["ou_xxx"],
    "wsUrl": "wss://open.feishu.cn/open-apis/ws/v2",
    "allowedOpenIds": [],
    "behavior": {
      "enableP2p": true,
      "enableGroup": true,
      "requireBotMentionInGroup": true,
      "strictBotMention": true,
      "ignoreNonUserSenders": true,
      "replyInThread": true
    },
    "cardActions": {
      "enabled": false,
      "path": "/webhook/card",
      "verificationToken": "",
      "encryptKey": ""
    }
  },
  "opencode": {
    "baseUrl": "http://127.0.0.1:4096/",
    "directory": "E:\\.Software\\OpenCode"
  },
  "storage": {
    "dataDir": "./data",
    "mappingsFile": "mappings.json"
  },
  "server": {
    "host": "127.0.0.1",
    "port": 3000,
    "publicBaseUrl": "https://bridge.example.com/"
  },
  "whitelist": {
    "storePath": "whitelist.json"
  },
  "bridge": {
    "queueLimit": 3,
    "sessions": {
      "p2pMode": "multi",
      "groupMode": "single",
      "topicGroupMode": "single",
      "maxSessionsPerWindow": 20,
      "listLimit": 10,
      "injectSystemState": true
    },
    "timeouts": {
      "firstEvent": 30000,
      "eventInterval": 120000,
      "totalTurn": 300000
    }
  },
  "embeddings": {
    "provider": {
      "baseUrl": "https://api.openai.com/v1/",
      "apiKey": "sk-xxx",
      "model": "text-embedding-3-small"
    },
    "similarityThreshold": 0.75
  },
  "memory": {
    "enabled": false,
    "dbPath": "./data/memory.db",
    "maxMemoriesPerUser": 500,
    "searchLimit": 5,
    "extractQueueLimit": 100,
    "sourcePreviewLength": 50,
    "shutdownDrainTimeoutMs": 5000,
    "retriever": "recent",
    "obsidian": {
      "enabled": false,
      "vaultPath": "/absolute/path/to/vault",
      "syncCron": "0 2 * * *",
      "enableWikiLinks": false
    }
  },
  "extensions": {
    "knowledge-base": {
      "enabled": false,
      "autoDetect": {
        "enabled": true,
        "minConfidence": 0.75
      },
      "query": {
        "topK": 10,
        "finalTopN": 3,
        "keywordFallbackLimit": 10
      },
      "storage": {
        "sqlitePath": "./data/knowledge-base.db",
        "bitable": {
          "appToken": "bascn_xxx",
          "tableId": "tbl_xxx",
          "documentTableId": "tbl_doc_xxx",
          "sourceFileField": {
            "name": "源文件",
            "type": "text",
            "urlTemplate": "https://example.com/knowledge/{{messageId}}/{{fileKey}}",
            "textTemplate": "{{fileName}}"
          },
          "statuteField": {
            "name": "法条",
            "type": "text",
            "urlTemplate": "https://example.com/law?keyword={{statute}}",
            "textTemplate": "{{statute}}"
          }
        }
      },
      "models": {
        "default": "minimax-cn-coding-plan/MiniMax-M2.7",
        "webRead": "minimax-cn-coding-plan/MiniMax-M2.7",
        "extract": "minimax-cn-coding-plan/MiniMax-M2.7",
        "rerank": "minimax-cn-coding-plan/MiniMax-M2.7"
      },
      "ingest": {
        "allowedExtensions": [".pdf", ".docx", ".txt", ".md"],
        "maxFileSizeMb": 20,
        "sessionIdleMs": 1800000,
        "concurrency": 3,
        "maxExtractChunks": 30,
        "maxExtractQas": 500
      },
      "parser": {
        "externalApiEnabled": false,
        "pdfProviderOrder": ["pdf-parse", "pymupdf4llm", "docling", "mineru-agent"],
        "imageProviderOrder": ["mineru-agent", "paddleocr-vl", "tesseract"],
        "ocrLang": "chi_sim+eng",
        "timeoutMs": 180000,
        "pollIntervalMs": 5000,
        "maxPollMs": 180000,
        "mineru": {
          "enabled": false,
          "endpoint": "https://mineru.net/api/v1/agent",
          "apiKey": ""
        },
        "paddleocr": {
          "enabled": false,
          "apiKey": "",
          "secretKey": ""
        }
      }
    },
    "contract-assistant": {
      "enabled": false,
      "storage": {
        "baseToken": "bascn_xxx",
        "contractTableId": "tbl_contract_xxx",
        "invoiceTableId": "tbl_invoice_xxx",
        "caseTableId": "tbl_case_xxx"
      },
      "models": {
        "default": "minimax-cn-coding-plan/MiniMax-M2.7",
        "draft": "minimax-cn-coding-plan/MiniMax-M2.7",
        "extract": "minimax-cn-coding-plan/MiniMax-M2.7",
        "invoice": "minimax-cn-coding-plan/MiniMax-M2.7",
        "caseManage": "minimax-cn-coding-plan/MiniMax-M2.7"
      },
      "ingest": {
        "contractAllowedExtensions": [".pdf", ".docx", ".txt", ".md"],
        "invoiceAllowedExtensions": [".pdf", ".png", ".jpg", ".jpeg", ".webp", ".txt", ".md"],
        "maxFileSizeMb": 20,
        "pendingTtlMs": 600000
      },
      "reminder": {
        "enabled": false,
        "targetChatIds": [],
        "hour": 9,
        "minute": 0,
        "lookaheadDays": 7
      }
    },
    "labor-skill": {
      "enabled": false,
      "models": {
        "default": "minimax-cn-coding-plan/MiniMax-M2.7",
        "extract": "minimax-cn-coding-plan/MiniMax-M2.7",
        "analyze": "minimax-cn-coding-plan/MiniMax-M2.7"
      },
      "ingest": {
        "allowedExtensions": [".pdf", ".docx", ".txt", ".md", ".png", ".jpg", ".jpeg", ".webp", ".xls", ".xlsx", ".csv"],
        "maxFileSizeMb": 20,
        "pendingTtlMs": 600000
      }
    }
  },
  "logging": {
    "dir": "./logs",
    "level": "info",
    "enableTranscript": true,
    "enableConsole": true,
    "enableColor": true,
    "rotateDaily": true
  }
}
